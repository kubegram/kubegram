{
  "name": "@kubegram/common-ts",
  "version": "1.4.2",
  "publishConfig": {
    "registry": "https://npm.pkg.github.com",
    "access": "public"
  },
  "description": "TypeScript GraphQL SDK for Kubegram infrastructure management",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "npmignore": [
    "src/graphql/*.graphql",
    "src/graphql/generated/schema.graphql",
    "src/graphql/operations.graphql",
    "*.graphql",
    "**/*.graphql"
  ],
  "scripts": {
    "build": "tsc",
    "clean": "rm -rf dist",
    "prebuild": "bun run clean",
    "prepublishOnly": "bun run build",
    "codegen": "graphql-codegen --config codegen.yml",
    "codegen:watch": "graphql-codegen --config codegen.yml --watch",
    "test": "bun test",
    "test:watch": "bun test --watch",
    "test:coverage": "bun test --coverage",
    "test:integration": "SKIP_INTEGRATION_TESTS=false bun test integration.test.ts",
    "test:integration:verbose": "SKIP_INTEGRATION_TESTS=false bun test integration.test.ts --verbose",
    "test:unit": "SKIP_INTEGRATION_TESTS=true bun test",
    "test:ci": "SKIP_INTEGRATION_TESTS=true bun test --coverage",
    "test:ci-no-coverage": "SKIP_INTEGRATION_TESTS=true bun test",
    "test:debug": "bun test --inspect-brk",
    "lint": "eslint src/**/*.ts --ignore-pattern '**/__tests__/**' --ignore-pattern '**/*.test.ts' --no-warn-ignored",
    "lint:fix": "eslint src/**/*.ts --ignore-pattern '**/__tests__/**' --ignore-pattern '**/*.test.ts' --no-warn-ignored --fix",
    "format": "prettier --write src/**/*.ts",
    "format:check": "prettier --check src/**/*.ts",
    "type-check": "tsc --noEmit",
    "check-all": "bun run type-check && bun run lint && bun run format:check && bun run test:ci"
  },
  "keywords": [
    "kubernetes",
    "service-mesh",
    "istio",
    "linkerd",
    "nginx",
    "traefik",
    "haproxy",
    "argocd",
    "flux",
    "gitops",
    "typescript",
    "graph",
    "validation",
    "AI"
  ],
  "author": "Kubegram",
  "license": "BUSL-1.1",
  "repository": {
    "type": "git",
    "url": "https://github.com/kubegram/kubegram.git",
    "directory": "common-ts"
  },
  "bugs": {
    "url": "https://github.com/kubegram/kubegram/issues"
  },
  "homepage": "https://github.com/kubegram/kubegram/tree/main/common-ts#readme",
  "devDependencies": {
    "@ai-sdk/anthropic": "^3.0.58",
    "@ai-sdk/google": "^3.0.43",
    "@ai-sdk/openai": "^3.0.41",
    "@graphql-codegen/cli": "^6.0.0",
    "@graphql-codegen/schema-ast": "^5.0.0",
    "@graphql-codegen/typescript": "^5.0.0",
    "@graphql-codegen/typescript-graphql-request": "^4.4.9",
    "@graphql-codegen/typescript-react-apollo": "^3.2.15",
    "@graphql-codegen/typescript-resolvers": "^5.0.0",
    "@types/minimist": "^1.2.5",
    "@types/mustache": "^4.2.6",
    "@types/node": "^24.10.11",
    "@eslint/js": "^9.0.0",
    "@typescript-eslint/eslint-plugin": "^8.56.1",
    "@typescript-eslint/parser": "^8.56.1",
    "ai": "^6.0.116",
    "eslint": "^9.0.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.4",
    "graphql": "^16.11.0",
    "graphql-tag": "^2.12.6",
    "graphql-yoga": "^5.15.2",
    "prettier": "^3.6.2",
    "typescript": "^5.9.2"
  },
  "dependencies": {
    "axios": "^1.11.0",
    "graphql-request": "^7.4.0",
    "zod": "^3.23.8"
  }
}
