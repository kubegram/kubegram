{
  "name": "@kubegram/github-app",
  "version": "1.0.0",
  "description": "GitHub App for Kubegram deployment event integration",
  "main": "dist/app.js",
  "scripts": {
    "dev": "bun --watch src/app.ts",
    "build": "tsc",
    "start": "bun dist/app.js",
    "test": "vitest",
    "test:watch": "vitest --watch",
    "test:coverage": "vitest --coverage",
    "test:ci": "vitest run --coverage",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix",
    "type-check": "tsc --noEmit",
    "check-all": "bun run type-check && bun run lint && bun run test:ci",
    "docker:build": "docker build -t kubegram/github-app .",
    "docker:run": "docker run -p 3000:3000 kubegram/github-app"
  },
  "keywords": [
    "github",
    "github-app",
    "kubegram",
    "kubernetes",
    "events",
    "webhooks"
  ],
  "author": "Kubegram",
  "license": "BUSL-1.1",
  "dependencies": {
    "@ai-sdk/anthropic": "3.0.58",
    "@ai-sdk/google": "3.0.43",
    "@ai-sdk/openai": "3.0.41",
    "@kubegram/events": "^1.0.0",
    "@octokit/app": "^16.1.2",
    "@octokit/auth-app": "^8.1.2",
    "@octokit/webhooks": "^14.2.0",
    "ai": "6.0.116",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.18.2",
    "helmet": "^7.1.0",
    "winston": "^3.11.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^20.11.17",
    "@typescript-eslint/eslint-plugin": "^8.56.1",
    "@typescript-eslint/parser": "^8.56.1",
    "@vitest/coverage-v8": "^4.0.18",
    "@eslint/js": "^9.0.0",
    "eslint": "^9.0.0",
    "typescript": "^5.3.3",
    "vitest": "^4.0.18"
  },
  "engines": {
    "bun": ">=1.0.0"
  }
}
