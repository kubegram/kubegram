# Environment Variables Template
# Copy this file to .env and fill in your actual values

# Required - GitHub App Configuration
GITHUB_APP_ID=your_github_app_id
GITHUB_PRIVATE_KEY=-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----
GITHUB_WEBHOOK_SECRET=your_webhook_secret

# Optional - GitHub OAuth (for user-based operations)
GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret

# Application Configuration
NODE_ENV=development
PORT=3000
LOG_LEVEL=info

# Kubegram Integration
KUBEGRAM_EVENT_BUS_URL=http://localhost:8090
KUBEGRAM_EVENT_BUS_API_KEY=your_kubegram_api_key
# Shared secret used to authenticate calls between kubegram-server and kubegram-github-app
KUBEGRAM_INTERNAL_SECRET=your_random_shared_secret
# URL of kubegram-server (used to call /api/internal/github/pr-merged on PR merge)
KUBEGRAM_SERVER_URL=http://kubegram-server:8090

# Security Configuration
CORS_ORIGINS=https://github.com,http://localhost:3000
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# Health Check Configuration
HEALTH_CHECK_INTERVAL=30000