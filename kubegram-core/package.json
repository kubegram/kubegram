{
  "name": "@kubegram/kubegram-core",
  "version": "0.1.1",
  "publishConfig": {
    "registry": "https://npm.pkg.github.com",
    "access": "public"
  },
  "description": "Core library for Kubegram - codegen, planning, MCP, and RAG functionality",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "clean": "rm -rf dist",
    "prebuild": "bun run clean",
    "prepublishOnly": "bun run build",
    "test": "bun test",
    "test:watch": "bun test --watch",
    "test:coverage": "bun test --coverage",
    "test:ci": "bun test --coverage",
    "lint": "eslint src/**/*.ts --no-warn-ignored",
    "lint:fix": "eslint src/**/*.ts --no-warn-ignored --fix",
    "format": "prettier --write src/**/*.ts",
    "format:check": "prettier --check src/**/*.ts",
    "type-check": "tsc --noEmit",
    "check-all": "bun run type-check && bun run lint && bun run format:check && bun run test:ci"
  },
  "keywords": [
    "kubernetes",
    "codegen",
    "infrastructure",
    "mcp",
    "rag",
    "llm",
    "ai"
  ],
  "author": "Kubegram",
  "license": "BUSL-1.1",
  "repository": {
    "type": "git",
    "url": "https://github.com/kubegram/kubegram.git",
    "directory": "kubegram-core"
  },
  "bugs": {
    "url": "https://github.com/kubegram/kubegram/issues"
  },
  "homepage": "https://github.com/kubegram/kubegram/tree/main/kubegram-core#readme",
  "devDependencies": {
    "@types/node": "^24.10.13",
    "@types/uuid": "^10.0.0",
    "@typescript-eslint/eslint-plugin": "^8.42.0",
    "@typescript-eslint/parser": "^8.42.0",
    "eslint": "^9.0.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.4",
    "prettier": "^3.6.2",
    "typescript": "^5.9.2"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.58",
    "@ai-sdk/google": "^3.0.43",
    "@ai-sdk/openai": "^3.0.41",
    "@kubegram/events": "^1.0.0",
    "ai": "^6.0.116",
    "ioredis": "^5.4.2",
    "uuid": "^11.1.0",
    "zod": "^3.23.8"
  },
  "peerDependencies": {
    "redis": "^4.7.1"
  },
  "peerDependenciesMeta": {
    "redis": {
      "optional": true
    }
  }
}
